@model LMS.Api.Areas.GiangVien.ViewModels.KhoaHocFormViewModel

@{
    ViewData["Title"] = "Tạo khóa học mới";
}

<div class="form-container">
    <div class="form-header">
        <a href="http://localhost:5173/instructor/courses" class="back-link">
            <span class="back-icon">&larr;</span> Quay lại danh sách
        </a>
        <h1 class="form-title">Tạo khóa học mới</h1>
        <p class="form-subtitle">Điền đầy đủ thông tin chi tiết để bắt đầu tạo khóa học mới.</p>
    </div>

    <div class="form-card">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="KhoaHoc.TieuDe" class="form-label">Tiêu đề khóa học</label>
                <input asp-for="KhoaHoc.TieuDe" class="form-input" placeholder="Ví dụ: Lập trình ASP.NET Core MVC từ cơ bản đến nâng cao" />
                <span asp-validation-for="KhoaHoc.TieuDe" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group flex-1">
                    <label asp-for="KhoaHoc.DanhMucId" class="form-label">Ngành / mảng của khóa học</label>
                    <select asp-for="KhoaHoc.DanhMucId" asp-items="Model.DanhSachDanhMuc" class="form-select">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="KhoaHoc.DanhMucId" class="field-validation-error"></span>
                </div>

                <div class="form-group flex-1">
                    <label asp-for="KhoaHoc.TrinhDo" class="form-label">Trình độ tối thiểu</label>
                    <select asp-for="KhoaHoc.TrinhDo" class="form-select">
                        <option value="BEGINNER">Cơ bản (Beginner)</option>
                        <option value="INTERMEDIATE">Trung cấp (Intermediate)</option>
                        <option value="ADVANCED">Nâng cao (Advanced)</option>
                    </select>
                    <span asp-validation-for="KhoaHoc.TrinhDo" class="field-validation-error"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group flex-1">
                    <label asp-for="KhoaHoc.Gia" class="form-label">Học phí (VND)</label>
                    <input asp-for="KhoaHoc.Gia" type="number" min="0" class="form-input" placeholder="Nhập 0 nếu miễn phí" />
                    <span asp-validation-for="KhoaHoc.Gia" class="field-validation-error"></span>
                </div>

                <div class="form-group flex-1">
                    <label class="form-label">Ảnh bìa khóa học</label>
                    <div class="file-input-wrapper">
                        <input type="file" name="CoverImageFile" id="CoverImageFile" accept="image/*" class="file-input" />
                        <label for="CoverImageFile" class="file-label">Chọn ảnh từ thiết bị</label>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="KhoaHoc.MoTaNgan" class="form-label">Mô tả ngắn</label>
                <input asp-for="KhoaHoc.MoTaNgan" class="form-input" placeholder="Tóm tắt ngắn gọn khóa học trong 1-2 câu" />
                <span asp-validation-for="KhoaHoc.MoTaNgan" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="KhoaHoc.MoTa" class="form-label">Mô tả khóa học</label>
                <textarea asp-for="KhoaHoc.MoTa" class="form-textarea" placeholder="Giới thiệu chi tiết về nội dung khóa học"></textarea>
                <span asp-validation-for="KhoaHoc.MoTa" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="KhoaHoc.MoTaChiTiet" class="form-label">Mô tả chi tiết (Tùy chọn)</label>
                <textarea asp-for="KhoaHoc.MoTaChiTiet" class="form-textarea height-large" placeholder="Những yêu cầu kiến thức, đối tượng học viên hoặc lợi ích khóa học mang lại..."></textarea>
                <span asp-validation-for="KhoaHoc.MoTaChiTiet" class="field-validation-error"></span>
            </div>

            <div class="form-actions">
                <a href="http://localhost:5173/instructor/courses" class="btn btn-secondary">Hủy</a>
                <button type="submit" class="btn btn-primary">Tạo khóa học</button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        .form-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px 0;
        }
        .form-header {
            margin-bottom: 28px;
        }
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            font-weight: 600;
            color: #64748b;
            margin-bottom: 12px;
            transition: color 0.2s;
        }
        .back-link:hover {
            color: #7c3aed;
        }
        .form-title {
            font-size: 28px;
            font-weight: 800;
            color: #0f172a;
            margin: 0 0 6px 0;
            letter-spacing: -0.02em;
        }
        .form-subtitle {
            font-size: 14px;
            color: #64748b;
            margin: 0;
        }
        .form-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            padding: 32px;
            box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05), 0 2px 4px -2px rgb(0 0 0 / 0.05);
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-row {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }
        .form-row .form-group {
            margin-bottom: 0;
        }
        .flex-1 {
            flex: 1;
        }
        .form-label {
            display: block;
            font-size: 13.5px;
            font-weight: 700;
            color: #334155;
            margin-bottom: 8px;
        }
        .form-input, .form-select, .form-textarea {
            width: 100%;
            padding: 12px 16px;
            font-size: 14px;
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            background-color: #f8fafc;
            color: #0f172a;
            outline: none;
            transition: all 0.2s;
        }
        .form-input:focus, .form-select:focus, .form-textarea:focus {
            border-color: #7c3aed;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(124, 58, 237, 0.1);
        }
        .form-textarea {
            min-height: 120px;
            resize: vertical;
        }
        .height-large {
            min-height: 180px;
        }
        .file-input-wrapper {
            position: relative;
            display: inline-block;
            width: 100%;
        }
        .file-input {
            position: absolute;
            left: 0;
            top: 0;
            opacity: 0;
            width: 100%;
            height: 100%;
            cursor: pointer;
        }
        .file-label {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 12px 16px;
            border: 1px dashed #cbd5e1;
            border-radius: 12px;
            background-color: #f8fafc;
            color: #475569;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }
        .file-input:hover + .file-label {
            background-color: #f1f5f9;
            border-color: #94a3b8;
        }
        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 32px;
            padding-top: 24px;
            border-t: 1px solid #e2e8f0;
        }
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 12px 24px;
            font-size: 14px;
            font-weight: 750;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
        }
        .btn-primary {
            background: linear-gradient(135deg, #a855f7, #7c3aed);
            color: #ffffff;
            box-shadow: 0 4px 10px rgba(124, 58, 237, 0.25);
        }
        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 14px rgba(124, 58, 237, 0.35);
        }
        .btn-secondary {
            background-color: #ffffff;
            border: 1px solid #cbd5e1;
            color: #475569;
        }
        .btn-secondary:hover {
            background-color: #f8fafc;
            color: #0f172a;
        }
        .validation-summary {
            padding: 12px 16px;
            border-radius: 12px;
            background-color: #fef2f2;
            border: 1px solid #fca5a5;
            color: #991b1b;
            margin-bottom: 24px;
            font-size: 14px;
        }
        .field-validation-error {
            display: block;
            margin-top: 6px;
            font-size: 13px;
            font-weight: 500;
            color: #dc2626;
        }
    </style>
}
