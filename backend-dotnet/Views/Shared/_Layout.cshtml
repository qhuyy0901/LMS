<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Skillio LMS</title>
    <style>
        :root {
            color-scheme: light;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            --primary: #7c3aed;
            --primary-dark: #6d28d9;
            --text: #0f172a;
            --muted: #64748b;
            --line: #e2e8f0;
            --surface: #ffffff;
            --page: #f8fafc;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: var(--page);
            color: var(--text);
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        .shell {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 260px 1fr;
        }

        .sidebar {
            background: var(--surface);
            border-right: 1px solid var(--line);
            padding: 28px 22px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 32px;
            font-weight: 800;
            font-size: 24px;
            color: var(--primary-dark);
        }

        .brand-mark {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: linear-gradient(135deg, #a855f7, #7c3aed);
            display: grid;
            place-items: center;
            color: #fff;
            font-weight: 900;
        }

        .nav-label {
            margin: 24px 0 10px;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .11em;
            text-transform: uppercase;
            color: #94a3b8;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            border-radius: 12px;
            padding: 11px 12px;
            color: #475569;
            font-size: 14px;
            font-weight: 650;
        }

        .nav-item.active {
            background: #f3e8ff;
            color: var(--primary-dark);
        }

        .content {
            padding: 28px;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 24px;
        }

        .search {
            flex: 1;
            min-height: 46px;
            border: 1px solid var(--line);
            border-radius: 999px;
            background: var(--surface);
            color: var(--muted);
            display: flex;
            align-items: center;
            padding: 0 18px;
            font-size: 14px;
        }

        .pill {
            border: 1px solid var(--line);
            border-radius: 999px;
            background: var(--surface);
            padding: 10px 14px;
            color: var(--muted);
            font-size: 13px;
            font-weight: 700;
        }

        .page {
            max-width: 1180px;
            margin: 0 auto;
        }

        @@media (max-width: 900px) {
            .shell {
                grid-template-columns: 1fr;
            }

            .sidebar {
                display: none;
            }

            .content {
                padding: 18px;
            }

            .topbar {
                display: none;
            }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="shell">
        <aside class="sidebar">
            <a class="brand" href="http://localhost:5173/">
                <span class="brand-mark">S</span>
                <span>Skillio</span>
            </a>

            @{
                var path = Context.Request.Path.Value ?? "";
                if (path.StartsWith("/Admin", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="nav-label">Tổng quan</div>
                    <a class="nav-item" href="http://localhost:5173/admin">Dashboard Admin</a>

                    <div class="nav-label">Quản trị hệ thống</div>
                    <a class="nav-item" href="http://localhost:5173/admin/users">Quản lý người dùng</a>
                    <a class="nav-item" href="http://localhost:5173/admin/instructor-applications">Đăng ký giảng viên</a>
                    <a class="nav-item" href="http://localhost:5173/admin/courses">Duyệt khóa học</a>
                    <a class="nav-item active" href="/Admin/DanhMuc">Quản lý danh mục</a>
                    <a class="nav-item" href="http://localhost:5173/admin/transactions">Quản lý giao dịch</a>
                    <a class="nav-item" href="http://localhost:5173/admin/events">Sự kiện</a>
                }
                else if (path.StartsWith("/Instructor", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="nav-label">Tổng quan</div>
                    <a class="nav-item" href="http://localhost:5173/instructor/dashboard">Dashboard giảng viên</a>

                    <div class="nav-label">Quản lý nội dung</div>
                    <a class="nav-item" href="http://localhost:5173/instructor/courses">Khóa học của tôi</a>
                    <a class="nav-item @(path.EndsWith("/Create", StringComparison.OrdinalIgnoreCase) ? "active" : "")" href="/Instructor/KhoaHoc/Create">Tạo khóa học mới</a>
                    <a class="nav-item" href="http://localhost:5173/instructor/vouchers">Mã giảm giá</a>
                    <a class="nav-item" href="http://localhost:5173/instructor/events">Quản lý sự kiện</a>

                    <div class="nav-label">Doanh thu</div>
                    <a class="nav-item" href="http://localhost:5173/instructor/wallet">Ví doanh thu</a>
                }
                else
                {
                    <div class="nav-label">Tổng quan</div>
                    <a class="nav-item" href="http://localhost:5173/">Bảng điều khiển</a>
                    <a class="nav-item active" href="/KhamPha">Khám phá</a>
                    <a class="nav-item" href="http://localhost:5173/events">Sự kiện</a>

                    <div class="nav-label">Học tập</div>
                    <a class="nav-item" href="http://localhost:5173/my-learning">Học tập của tôi</a>
                    <a class="nav-item" href="http://localhost:5173/reports">Tiến trình</a>

                    <div class="nav-label">Tài khoản</div>
                    <a class="nav-item" href="http://localhost:5173/messages">Tin nhắn</a>
                    <a class="nav-item" href="http://localhost:5173/instructors">Giảng viên</a>
                    <a class="nav-item" href="http://localhost:5173/settings">Cài đặt</a>
                }
            }
        </aside>
        <main class="content">
            <div class="topbar">
                <form action="/KhamPha" method="get" class="search" style="margin: 0; display: flex; align-items: center; width: 100%; max-width: 400px;">
                    <input type="text" name="search" value="@ViewData["SearchQuery"]" placeholder="Tìm kiếm khóa học, chủ đề..." style="width: 100%; border: none; outline: none; background: transparent; font-size: 14px; color: var(--text);" />
                </form>
                <a class="pill" href="http://localhost:5173/">Về ứng dụng</a>
            </div>
            <div class="page">
                @RenderBody()
            </div>
        </main>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
