datasource db {
  provider = "sqlserver"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String
  password      String
  role          String     @default("STUDENT")
  avatar        String?
  phone         String?
  bio           String?
  settings      String?
  walletBalance Int        @default(0)
  totalSpent    Int        @default(0)
  memberTier    String     @default("BRONZE")

  courses            Course[]
  enrollments        Enrollment[]
  lessonProgress     LessonProgress[]
  comments           Comment[]
  reviews            CourseReview[]
  walletTransactions WalletTransaction[]
  purchases          Purchase[]
  externalPayments   ExternalPayment[]
  notifications      Notification[]
  certificates       Certificate[]
  quizSubmissions    QuizSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Course {
  id                 String     @id @default(cuid())
  title              String
  slug               String     @unique
  description        String?
  thumbnail          String?
  price              Int        @default(0)
  averageRating      Float      @default(0)
  reviewCount        Int        @default(0)
  minimumMemberTier  String     @default("BRONZE")
  totalDurationSeconds Int      @default(0)
  isPublished        Boolean    @default(false)
  publishedAt        DateTime?

  instructorId String
  instructor   User   @relation(fields: [instructorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  sections           Section[]
  lessons            Lesson[]
  enrollments        Enrollment[]
  reviews            CourseReview[]
  walletTransactions WalletTransaction[]
  purchases          Purchase[]
  certificates       Certificate[]
  coupons            Coupon[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId])
  @@index([isPublished, createdAt])
  @@index([slug])
}

model CourseReview {
  id      String  @id @default(cuid())
  rating  Int
  comment String?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([courseId, createdAt])
  @@index([userId, createdAt])
}

model Section {
  id          String  @id @default(cuid())
  title       String
  description String?
  position    Int

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  lessons   Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
  @@unique([courseId, position])
}

model Lesson {
  id              String  @id @default(cuid())
  title           String
  content         String?
  videoUrl        String?
  durationSeconds Int?
  position        Int
  isPublished     Boolean @default(false)
  isPreview       Boolean @default(false)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  lessonProgress LessonProgress[]
  comments       Comment[]
  quiz           Quiz?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
  @@index([sectionId])
  @@index([courseId, isPreview])
  @@unique([sectionId, position])
}

model Enrollment {
  id       String @id @default(cuid())
  progress Float  @default(0)
  completedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([courseId, createdAt])
  @@index([userId, updatedAt])
}

model LessonProgress {
  id          String  @id @default(cuid())
  isCompleted Boolean @default(false)
  watchedSeconds Int @default(0)
  lastPositionSeconds Int @default(0)
  completionRate Float @default(0)
  completedAt DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@index([userId, isCompleted])
}

model Comment {
  id      String @id @default(cuid())
  content String

  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies  Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lessonId])
  @@index([userId])
}

model WalletTransaction {
  id           String                @id @default(cuid())
  type         String
  amount       Int
  balanceAfter Int
  note         String?
  metadata     String? @db.NVarChar(4000)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  purchaseId String?
  purchase   Purchase? @relation(fields: [purchaseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  externalPaymentId String?
  externalPayment   ExternalPayment? @relation(fields: [externalPaymentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([courseId])
  @@index([type, createdAt])
}

model Purchase {
  id             String         @id @default(cuid())
  originalAmount Int
  discountAmount Int            @default(0)
  finalAmount    Int
  currency       String         @default("VND")
  status         String         @default("COMPLETED")

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  walletTransactions WalletTransaction[]
  couponId          String?
  coupon            Coupon?   @relation(fields: [couponId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([courseId, createdAt])
  @@index([userId, createdAt])
}

model ExternalPayment {
  id                      String                @id @default(cuid())
  provider                String
  status                  String                @default("PENDING")
  amount                  Int
  currency                String                @default("VND")
  note                    String?
  providerSessionId       String                @unique
  providerPaymentIntentId String?
  completedAt             DateTime?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  walletTransactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model ProcessedWebhookEvent {
  id              String          @id @default(cuid())
  provider        String
  providerEventId String          @unique
  payload         String?         @db.NVarChar(4000)
  processedAt     DateTime        @default(now())

  @@index([provider, processedAt])
}

model Notification {
  id       String           @id @default(cuid())
  type     String
  title    String
  body     String
  link     String?
  isRead   Boolean          @default(false)
  metadata String? @db.NVarChar(4000)
  readAt   DateTime?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
}

model Certificate {
  id                 String   @id @default(cuid())
  certificateNo      String   @unique
  verifyCode         String   @unique
  pdfUrl             String?
  completionSnapshot String?   @db.NVarChar(4000)
  issuedAt           DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, courseId])
  @@index([courseId, issuedAt])
  @@index([userId, issuedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     String
  entityType String
  entityId   String?
  metadata   String?  @db.NVarChar(4000)
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

model Coupon {
  id                String     @id @default(cuid())
  code              String     @unique
  discountType      String     @default("PERCENTAGE")
  discountValue     Int
  minPurchaseAmount Int        @default(0)
  maxDiscountAmount Int?
  startDate         DateTime?
  endDate           DateTime?
  isActive          Boolean    @default(true)
  usageLimit        Int?
  usageCount        Int        @default(0)

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  purchases Purchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([courseId])
}

model Quiz {
  id           String          @id @default(cuid())
  title        String
  description  String?
  passingScore Int             @default(80)
  
  lessonId     String          @unique
  lesson       Lesson          @relation(fields: [lessonId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  questions    QuizQuestion[]
  submissions  QuizSubmission[]

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model QuizQuestion {
  id                 String   @id @default(cuid())
  questionText       String
  options            String @db.NVarChar(4000)
  correctOptionIndex Int
  explanation        String?
  position           Int

  quizId             String
  quiz               Quiz     @relation(fields: [quizId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([quizId])
}

model QuizSubmission {
  id        String   @id @default(cuid())
  score     Float
  passed    Boolean
  answers   String   @db.NVarChar(4000)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([quizId])
}

